<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/totalCostText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total: $0"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/averageCostText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Average per person: $0"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/perUserCostText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Per roommate breakdown"
        android:textSize="18sp" />

    <Button
        android:id="@+id/settleButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Settle Costs" />

</LinearLayout>